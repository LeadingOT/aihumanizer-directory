---
import BaseLayout from '../layouts/BaseLayout.astro';
import ListingCard from '../components/ListingCard.astro';
import { getCollection } from 'astro:content';

const allListings = await getCollection('listings');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Best AI Humanizer Tools',
  description: 'Compare the best AI humanizer tools to make AI content undetectable',
  url: Astro.url.origin,
};
---

<BaseLayout
  title="Best AI Humanizer Tools (2026) - Make AI Text Undetectable"
  description="Compare the best AI humanizer tools to make AI-generated content undetectable. Bypass AI detectors. Free trials available."
  schema={schema}
>
  <!-- Hero -->
  <section class="text-center py-12">
    <h1 class="text-4xl font-bold mb-4">Best AI Humanizer Tools (2026)</h1>
    <p class="text-lg text-gray-600 max-w-2xl mx-auto">
      Discover and compare the top AI humanizer tools to make AI-generated content undetectable. Transform text, enhance images, and improve videos.
    </p>
  </section>

  <!-- Listings Grid -->
  <section>
    <h2 class="text-2xl font-bold mb-6">All Tools</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {allListings.map((listing) => (
        <ListingCard {...listing.data} />
      ))}
    </div>
  </section>
</BaseLayout>
