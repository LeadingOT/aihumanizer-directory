---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Import glossary JSON files directly
import accrualAccounting from '../../content/glossary/accrual-accounting.json';
import accountsPayable from '../../content/glossary/accounts-payable.json';
import accountsReceivable from '../../content/glossary/accounts-receivable.json';
import bankReconciliation from '../../content/glossary/bank-reconciliation.json';
import cashFlowStatement from '../../content/glossary/cash-flow-statement.json';
import chartOfAccounts from '../../content/glossary/chart-of-accounts.json';
import doubleEntryBookkeeping from '../../content/glossary/double-entry-bookkeeping.json';
import expenseCategorization from '../../content/glossary/expense-categorization.json';
import generalLedger from '../../content/glossary/general-ledger.json';
import taxCompliance from '../../content/glossary/tax-compliance.json';

const glossaryEntries = [
  accrualAccounting,
  accountsPayable,
  accountsReceivable,
  bankReconciliation,
  cashFlowStatement,
  chartOfAccounts,
  doubleEntryBookkeeping,
  expenseCategorization,
  generalLedger,
  taxCompliance,
].sort((a, b) => a.title.localeCompare(b.title));

const title = "Accounting & AI Glossary - Master Key Terms | AccountingAI.tools";
const description = "Complete glossary of accounting and AI automation terms. Learn accrual accounting, bank reconciliation, chart of accounts, and more with real examples.";

// Schema.org CollectionPage
const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description: description,
  numberOfItems: glossaryEntries.length
};
---

<BaseLayout {title} {description} schema={collectionSchema}>
  <div class="container mx-auto px-4 py-12 max-w-6xl">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        Accounting & AI Glossary
      </h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Master accounting concepts and AI automation. {glossaryEntries.length} terms explained with real examples and tool recommendations.
      </p>
    </div>

    <!-- Search (future enhancement placeholder) -->
    <div class="max-w-2xl mx-auto mb-12">
      <input 
        type="text" 
        id="glossary-search"
        placeholder="Search terms... (e.g., accrual, reconciliation)" 
        class="w-full px-6 py-4 border-2 border-gray-200 rounded-lg focus:border-blue-500 focus:outline-none text-lg"
      />
    </div>

    <!-- Glossary Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {glossaryEntries.map((entry) => (
        <a 
          href={`/glossary/${entry.slug}`}
          class="glossary-card block p-6 bg-white border-2 border-gray-200 rounded-lg hover:border-blue-500 hover:shadow-lg transition group"
        >
          <h2 class="text-xl font-bold mb-2 text-gray-900 group-hover:text-blue-600">
            {entry.title.replace(/:.+/, '')}
          </h2>
          <p class="text-gray-600 mb-3 line-clamp-3">
            {entry.description}
          </p>
          <div class="flex items-center justify-between text-sm text-gray-500">
            <span>⏱️ {entry.readingTime} min read</span>
            <span class="text-blue-600 group-hover:underline">Read more →</span>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA Section -->
    <div class="mt-16 bg-gradient-to-r from-blue-600 to-blue-700 rounded-2xl p-8 md:p-12 text-white text-center">
      <h2 class="text-3xl font-bold mb-4">
        Ready to Automate Your Accounting?
      </h2>
      <p class="text-xl mb-6 opacity-90">
        Explore AI-powered tools that implement these concepts automatically.
      </p>
      <a 
        href="/" 
        class="inline-block bg-white text-blue-600 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition"
      >
        Browse AI Accounting Tools
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  // Simple client-side search
  const searchInput = document.getElementById('glossary-search') as HTMLInputElement;
  const cards = document.querySelectorAll('.glossary-card');
  
  searchInput?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value.toLowerCase();
    
    cards.forEach((card) => {
      const text = card.textContent?.toLowerCase() || '';
      if (text.includes(query)) {
        (card as HTMLElement).style.display = 'block';
      } else {
        (card as HTMLElement).style.display = 'none';
      }
    });
  });
</script>
