---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { marked } from 'marked';

// Import all example entries
import autoInvoice from '../../content/examples/automate-invoice-processing.json';
import taxCompliance from '../../content/examples/ai-tax-compliance.json';
import setupBookkeeping from '../../content/examples/setup-ai-bookkeeping.json';
import chooseTool from '../../content/examples/choose-accounting-tool.json';
import migrate from '../../content/examples/migrate-to-ai-accounting.json';

export async function getStaticPaths() {
  const examples = [
    autoInvoice,
    taxCompliance,
    setupBookkeeping,
    chooseTool,
    migrate,
  ];
  
  return examples.map((example) => ({
    params: { slug: example.slug },
    props: { example },
  }));
}

const { example } = Astro.props;

const title = example.metaTitle || example.title;
const description = example.metaDescription;

// Schema.org HowTo
const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: example.title,
  description: example.summary,
  datePublished: example.lastUpdated,
  dateModified: example.lastUpdated,
  author: {
    '@type': 'Organization',
    name: 'AccountingAI.tools'
  }
};
---

<BaseLayout {title} {description} schema={howToSchema}>
  <div class="container mx-auto px-4 py-8 max-w-4xl">
    <!-- Breadcrumb -->
    <nav class="text-sm mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center space-x-2 text-gray-600">
        <li><a href="/" class="hover:text-blue-600">Home</a></li>
        <li><span class="mx-2">/</span></li>
        <li><a href="/examples" class="hover:text-blue-600">Guides</a></li>
        <li><span class="mx-2">/</span></li>
        <li class="text-gray-900">{example.title.replace(/^How to /, '')}</li>
      </ol>
    </nav>

    <!-- Article Header -->
    <div class="mb-8">
      <h1 class="text-4xl font-bold mb-4 text-gray-900">{example.title}</h1>
      
      <div class="flex items-center gap-4 text-sm text-gray-600 mb-4">
        <span>⏱️ {example.readTime}</span>
        <span>📅 {example.lastUpdated}</span>
      </div>

      <p class="text-xl text-gray-700 leading-relaxed">
        {example.summary}
      </p>
    </div>

    <!-- Table of Contents -->
    <div class="bg-gray-50 p-6 rounded-lg mb-8">
      <h2 class="text-lg font-semibold mb-3">📋 In This Guide</h2>
      <ul class="space-y-2">
        {example.sections.map((section) => (
          <li>
            <a 
              href={`#${section.heading.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}
              class="text-blue-600 hover:text-blue-800"
            >
              {section.heading}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Main Content -->
    <article class="prose prose-lg max-w-none">
      {example.sections.map((section) => (
        <div id={section.heading.toLowerCase().replace(/[^a-z0-9]+/g, '-')}>
          <h2>{section.heading}</h2>
          <div set:html={marked(section.content)} />
        </div>
      ))}
    </article>

    <!-- Related Tools -->
    {example.relatedTools && example.relatedTools.length > 0 && (
      <div class="mt-12 p-6 bg-blue-50 rounded-lg">
        <h3 class="text-xl font-semibold mb-4">🛠️ Recommended Tools for This Guide</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          {example.relatedTools.map((toolSlug) => (
            <a 
              href={`/listing/${toolSlug}/`}
              class="block p-4 bg-white rounded-lg hover:shadow-md transition border border-gray-200"
            >
              <span class="text-blue-600 font-medium capitalize">
                {toolSlug.replace(/-/g, ' ')}
              </span>
              <span class="text-gray-500 ml-2">→</span>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Related Examples -->
    {example.relatedExamples && example.relatedExamples.length > 0 && (
      <div class="mt-8 p-6 bg-green-50 rounded-lg">
        <h3 class="text-xl font-semibold mb-4">📚 Related Guides</h3>
        <div class="space-y-2">
          {example.relatedExamples.map((exampleSlug) => (
            <a 
              href={`/examples/${exampleSlug}/`}
              class="block p-3 bg-white rounded hover:shadow-md transition border border-gray-200"
            >
              <span class="text-green-600 font-medium capitalize">
                {exampleSlug.replace(/-/g, ' ')}
              </span>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- CTA -->
    <div class="mt-12 p-8 bg-gradient-to-r from-blue-600 to-purple-600 rounded-lg text-white text-center">
      <h3 class="text-2xl font-bold mb-3">Ready to Automate Your Accounting?</h3>
      <p class="text-lg mb-6 text-blue-50">
        Browse 59 AI accounting tools and find the perfect fit for your business.
      </p>
      <a 
        href="/" 
        class="inline-block bg-white text-blue-600 px-8 py-3 rounded-lg font-semibold hover:bg-blue-50 transition"
      >
        Explore All Tools
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  article :global(h2) {
    font-size: 1.75rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: #111827;
    border-bottom: 2px solid #e5e7eb;
    padding-bottom: 0.5rem;
  }

  article :global(h3) {
    font-size: 1.375rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: #1f2937;
  }

  article :global(h4) {
    font-size: 1.125rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: #374151;
  }

  article :global(p) {
    margin: 1rem 0;
    line-height: 1.75;
    color: #374151;
  }

  article :global(ul), article :global(ol) {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }

  article :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.625;
  }

  article :global(strong) {
    font-weight: 600;
    color: #111827;
  }

  article :global(code) {
    background-color: #f3f4f6;
    padding: 0.125rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    font-family: monospace;
  }

  article :global(pre) {
    background-color: #1f2937;
    color: #f9fafb;
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  article :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }

  article :global(th) {
    background-color: #f3f4f6;
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 600;
    border-bottom: 2px solid #d1d5db;
  }

  article :global(td) {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #e5e7eb;
  }

  article :global(blockquote) {
    border-left: 4px solid #3b82f6;
    padding-left: 1rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: #374151;
  }

  article :global(a) {
    color: #2563eb;
    text-decoration: underline;
  }

  article :global(a:hover) {
    color: #1e40af;
  }
</style>
