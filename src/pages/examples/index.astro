---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Import all examples
import autoInvoice from '../../content/examples/automate-invoice-processing.json';
import taxCompliance from '../../content/examples/ai-tax-compliance.json';
import setupBookkeeping from '../../content/examples/setup-ai-bookkeeping.json';
import chooseTool from '../../content/examples/choose-accounting-tool.json';
import migrate from '../../content/examples/migrate-to-ai-accounting.json';

const examples = [
  autoInvoice,
  taxCompliance,
  setupBookkeeping,
  chooseTool,
  migrate,
];

const title = "AI Accounting Guides & Tutorials | How to Automate Your Finances";
const description = "Step-by-step guides for automating accounting with AI. Learn invoice processing, tax compliance, bookkeeping setup, and tool selection. Updated March 2026.";

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description: description,
  author: {
    '@type': 'Organization',
    name: 'AccountingAI.tools'
  }
};
---

<BaseLayout {title} {description} {schema}>
  <div class="container mx-auto px-4 py-12 max-w-6xl">
    <!-- Page Header -->
    <div class="mb-12 text-center">
      <h1 class="text-5xl font-bold mb-4 text-gray-900">
        📚 AI Accounting Guides
      </h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Practical, step-by-step tutorials for automating your accounting workflow with AI tools. 
        From invoice processing to tax compliance—everything you need to go from manual to automated.
      </p>
    </div>

    <!-- Featured Guide -->
    <div class="mb-16">
      <div class="bg-gradient-to-r from-blue-600 to-purple-600 rounded-lg p-8 text-white">
        <div class="flex items-start gap-4">
          <span class="text-5xl">🚀</span>
          <div>
            <h2 class="text-2xl font-bold mb-2">
              <a href={`/examples/${examples[0].slug}/`} class="hover:underline">
                {examples[0].title}
              </a>
            </h2>
            <p class="text-blue-50 mb-4 text-lg">
              {examples[0].summary}
            </p>
            <div class="flex items-center gap-6 text-sm text-blue-100">
              <span>⏱️ {examples[0].readTime}</span>
              <span>📅 {examples[0].lastUpdated}</span>
            </div>
            <a 
              href={`/examples/${examples[0].slug}/`}
              class="inline-block mt-4 bg-white text-blue-600 px-6 py-2 rounded-lg font-semibold hover:bg-blue-50 transition"
            >
              Read Guide →
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- All Guides Grid -->
    <div class="mb-12">
      <h2 class="text-3xl font-bold mb-8 text-gray-900">All Guides</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {examples.map((example) => (
          <a 
            href={`/examples/${example.slug}/`}
            class="block group"
          >
            <div class="bg-white border border-gray-200 rounded-lg p-6 hover:shadow-lg hover:border-blue-300 transition h-full">
              <h3 class="text-xl font-semibold mb-3 text-gray-900 group-hover:text-blue-600">
                {example.title}
              </h3>
              <p class="text-gray-600 mb-4 line-clamp-3">
                {example.summary}
              </p>
              <div class="flex items-center gap-4 text-sm text-gray-500">
                <span>⏱️ {example.readTime}</span>
                <span>📅 {example.lastUpdated}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Guide Categories -->
    <div class="mb-16">
      <h2 class="text-3xl font-bold mb-8 text-gray-900">Browse by Topic</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Automation -->
        <div class="bg-blue-50 p-6 rounded-lg border border-blue-200">
          <h3 class="text-xl font-semibold mb-3 text-blue-900">
            🤖 Automation
          </h3>
          <ul class="space-y-2">
            <li>
              <a href="/examples/automate-invoice-processing/" class="text-blue-600 hover:underline">
                Invoice Processing
              </a>
            </li>
            <li>
              <a href="/examples/setup-ai-bookkeeping/" class="text-blue-600 hover:underline">
                Bookkeeping Setup
              </a>
            </li>
          </ul>
        </div>

        <!-- Tax & Compliance -->
        <div class="bg-green-50 p-6 rounded-lg border border-green-200">
          <h3 class="text-xl font-semibold mb-3 text-green-900">
            📊 Tax & Compliance
          </h3>
          <ul class="space-y-2">
            <li>
              <a href="/examples/ai-tax-compliance/" class="text-green-600 hover:underline">
                Tax Compliance
              </a>
            </li>
          </ul>
        </div>

        <!-- Getting Started -->
        <div class="bg-purple-50 p-6 rounded-lg border border-purple-200">
          <h3 class="text-xl font-semibold mb-3 text-purple-900">
            🎯 Getting Started
          </h3>
          <ul class="space-y-2">
            <li>
              <a href="/examples/choose-accounting-tool/" class="text-purple-600 hover:underline">
                Choose the Right Tool
              </a>
            </li>
            <li>
              <a href="/examples/migrate-to-ai-accounting/" class="text-purple-600 hover:underline">
                Migration Guide
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="text-center bg-gray-100 p-12 rounded-lg">
      <h2 class="text-3xl font-bold mb-4 text-gray-900">
        Ready to Find Your Perfect AI Accounting Tool?
      </h2>
      <p class="text-lg text-gray-600 mb-6 max-w-2xl mx-auto">
        Browse 59 AI accounting tools with honest reviews, pricing, and feature comparisons.
      </p>
      <a 
        href="/" 
        class="inline-block bg-blue-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-700 transition text-lg"
      >
        Explore All Tools
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
