---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import FAQSection from '../../components/FAQSection.astro';
import { getCollection } from 'astro:content';

const allListings = await getCollection('listings');
const tools = allListings
  .filter((l) => l.data.category === 'Forecasting & Planning')
  .sort((a, b) => (b.data.rating || 0) - (a.data.rating || 0));

const featureList = [
  'AI-powered forecasting',
  'Scenario planning',
  'Budget management',
  'Data consolidation',
  'Excel/spreadsheet native',
  'Real-time reporting',
  'Audit trails',
];

const faqs = [
  { question: 'What is AI financial forecasting software?', answer: 'AI financial forecasting software uses machine learning and statistical models to predict future financial performance based on historical data, market trends, and business drivers. These tools automate budgeting, scenario planning, and variance analysis.' },
  { question: 'How accurate is AI financial forecasting?', answer: 'AI forecasting typically improves accuracy by 20-40% compared to traditional spreadsheet-based methods, with continuous learning improving predictions over time as more data becomes available.' },
  { question: 'Do I need to replace Excel for AI forecasting?', answer: 'No — many top FP&A platforms like Datarails, Vena, and Cube are designed to work with Excel, adding AI capabilities on top of your existing spreadsheet workflows.' },
  { question: 'What size company benefits from AI forecasting tools?', answer: 'Companies with $5M+ in revenue typically see the most benefit, though tools like Cube offer accessible pricing for growing companies. Enterprise platforms like OneStream serve large organizations.' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Best AI Financial Forecasting & Planning Tools (2026)',
  datePublished: '2026-02-23',
  dateModified: '2026-02-23',
};
---

<BaseLayout
  title="Best AI Financial Forecasting & Planning Tools (2026)"
  description="Compare the best AI FP&A and forecasting software for 2026. Reviews of OneStream, Vena, Cube, and Datarails."
  schema={schema}
>
  <article class="max-w-4xl">
    <h1 class="text-3xl font-bold mb-4">Best AI Financial Forecasting & Planning Tools (2026)</h1>
    <p class="text-gray-600 mb-8">
      AI-powered FP&A tools transform financial planning with automated forecasting, intelligent scenario analysis, and real-time reporting. Here are the top platforms for finance teams.
    </p>

    <ComparisonTable items={tools.map((t) => t.data)} featureList={featureList} title="Feature Comparison" />

    <section class="mt-12">
      <h2 class="text-2xl font-bold mb-6">Detailed Reviews</h2>
      {tools.map((tool) => (
        <div class="border border-gray-200 rounded-lg p-6 mb-6">
          <div class="flex items-center justify-between mb-2">
            <h3 class="text-xl font-semibold">
              <a href={`/listing/${tool.data.slug}`} class="hover:text-blue-600">{tool.data.name}</a>
            </h3>
            {tool.data.rating && <span class="text-yellow-600">★ {tool.data.rating.toFixed(1)}</span>}
          </div>
          <p class="text-gray-600 mb-3">{tool.data.description}</p>
          <p class="text-sm"><strong>Pricing:</strong> {tool.data.pricing.startingPrice || tool.data.pricing.model}</p>
        </div>
      ))}
    </section>

    <FAQSection faqs={faqs} />
  </article>
</BaseLayout>
